# Copie este arquivo para `.env` e preencha com sua URL do Postgres.
# NUNCA coloque senhas reais aqui — o .env.example vai pro Git.
#
# Local (postgres instalado na máquina):
# DATABASE_URL=postgres://usuario:senha@localhost:5432/reptilia
#
# Render (External Database URL — dashboard do seu Postgres no Render):
# DATABASE_URL=postgres://user:pass@dpg-xxxxxx.oregon-postgres.render.com/reptilia_xxxx

DATABASE_URL=

# Porta local (opcional; Render define sozinho em produção)
PORT=3000
